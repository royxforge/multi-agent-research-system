# ── Required ──────────────────────────────────────────────────────
# Tavily API key for web search (get one at https://tavily.com)
TAVILY_API_KEY=tvly-your-key-here

# ── Local LLM (Ollama) ────────────────────────────────────────────
# Uncomment and configure to use local models
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Cloud LLM Providers (pick at least one) ──────────────────────

# OpenRouter (Grok, GPT-4, Claude, DeepSeek, etc.)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=x-ai/grok-4.1-fast

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google (Gemini)
# GOOGLE_API_KEY=your-key-here
# GOOGLE_MODEL=gemini-2.0-flash

# Perplexity
# PERPLEXITY_API_KEY=your-key-here
# PERPLEXITY_MODEL=sonar-pro

# Groq
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=mixtral-8x7b-32768

# Together AI
# TOGETHER_API_KEY=your-key-here
# TOGETHER_MODEL=mistralai/Mixtral-8x22B-Instruct-v0.1

# DeepSeek
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_MODEL=deepseek-chat

# Mistral
# MISTRAL_API_KEY=your-key-here
# MISTRAL_MODEL=mistral-large-latest

# ── Search Configuration ──────────────────────────────────────────
# Topic focus for Tavily search (default: general)
# TAVILY_TOPIC=general

# Max search results per query (default: 10)
# MAX_SEARCH_RESULTS=10

# Max context characters for LLM input (default: 12000)
# MAX_CONTEXT_CHARS=12000

# ── LLM Settings ──────────────────────────────────────────────────
# Seed for deterministic generation (default: 42)
# DEFAULT_SEED=42

# Temperature for LLM sampling (default: 0.2)
# DEFAULT_TEMPERATURE=0.2

# Top-p for nucleus sampling (default: 0.9)
# DEFAULT_TOP_P=0.9

# ── Application ───────────────────────────────────────────────────
# Log level (default: INFO)
# LOG_LEVEL=INFO

# Frontend origin for CORS (default: http://localhost:5173)
# FRONTEND_ORIGIN=http://localhost:5173

# ── LangSmith Tracing (optional) ──────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2-your-key-here
# LANGSMITH_PROJECT=auto-researcher
